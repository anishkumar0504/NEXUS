{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "sourceMap": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./*.ts", "./lib/**/*.ts", "./types/**/*.ts", "./middleware/**/*.ts", "./prompt/**/*.ts", "./server/**/*.ts", "./redis/**/*.ts"],
  "exclude": ["dist", "node_modules", "tests"]
}