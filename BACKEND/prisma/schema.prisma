generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id  // Supabase UUID comes as string
  name          String
  email         String         @unique
  provider      AuthProvider
  conversations Conversation[]
}

enum AuthProvider {
  GitHub
  Google
}

model Conversation {
  id        String    @id @default(cuid())
  title     String
  messages  Message[]
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
}

model Message {
  id             String       @id @default(cuid())
  content        String
  sources        Json?        // store sources array here
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
  createdAt      DateTime     @default(now())
  role           MessageRole
}

enum MessageRole {
  USER
  ASSISTANT
}

// Cache table so same queries don't hit Tavily again
model SearchCache {
  id        String   @id @default(cuid())
  query     String   @unique  // exact query string as key
  results   Json     // stored Tavily results
  createdAt DateTime @default(now())
  expiresAt DateTime // we check this before using cache
}