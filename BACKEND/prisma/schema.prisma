generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id
  name          String
  email         String         @unique
  provider      AuthProvider
  conversations Conversation[]
  groupChats    GroupMember[]
  groupMessages GroupMessage[]
}

enum AuthProvider {
  GitHub
  Google
}

model Conversation {
  id        String    @id @default(cuid())
  title     String
  messages  Message[]
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
}

model Message {
  id             String       @id @default(cuid())
  content        String
  sources        Json?        // store sources array here
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
  createdAt      DateTime     @default(now())
  role           MessageRole
}

enum MessageRole {
  USER
  ASSISTANT
}

// Cache table so same queries don't hit Tavily again
model SearchCache {
  id        String   @id @default(cuid())
  query     String   @unique  // exact query string as key
  results   Json     // stored Tavily results
  createdAt DateTime @default(now())
  expiresAt DateTime // we check this before using cache
}
model GroupChat {
  id        String        @id @default(cuid())
  name      String
  members   GroupMember[]
  messages  GroupMessage[]
  tasks     Task[]
  createdAt DateTime      @default(now())
}

model GroupMember {
  id          String    @id @default(cuid())
  groupChatId String
  userId      String
  groupChat   GroupChat @relation(fields: [groupChatId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  joinedAt    DateTime  @default(now())

  @@unique([groupChatId, userId])
}

model Agent {
  id        String         @id @default(cuid())
  name      String         @unique // e.g. "summarizer", "imagegen", "pdfgen"
  type      AgentType
  messages  GroupMessage[]
  tasks     Task[]
}

enum AgentType {
  SUMMARIZER
  IMAGE_GEN
  PDF_GEN
  ASSISTANT   
  RESEARCH    
}

model GroupMessage {
  id          String      @id @default(cuid())
  content     String
  sources     Json?
  groupChatId String
  groupChat   GroupChat   @relation(fields: [groupChatId], references: [id])
  triggeringUserId String?  // <-- ADD THIS

  senderType  SenderType
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  agentId     String?
  agent       Agent?      @relation(fields: [agentId], references: [id])

  createdAt   DateTime    @default(now())
}

enum SenderType {
  USER
  AGENT
  SYSTEM
}
model Task {
  id          String     @id @default(cuid())
  groupChatId String
  groupChat   GroupChat  @relation(fields: [groupChatId], references: [id])
  agentId     String
  agent       Agent      @relation(fields: [agentId], references: [id])
  prompt      String
  status      TaskStatus @default(PENDING)
  result      Json?
  createdAt   DateTime   @default(now())
  completedAt DateTime?
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}